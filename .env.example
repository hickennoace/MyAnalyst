# ──────────────────────────────────────────────────────────────
# Quantia — environment variable template.
# Copy to .env for local dev. In prod, use a secrets manager (Doppler / cloud KMS).
# NEVER commit a real .env.
# ──────────────────────────────────────────────────────────────

# --- App ---
APP_ENV=local                      # local | staging | production
APP_SECRET_KEY=change-me           # used to sign internal tokens
LOG_LEVEL=INFO

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# --- Database (Postgres) ---
DATABASE_URL=postgresql+psycopg://quantia:quantia@localhost:5432/quantia
# App connects as a role that CANNOT bypass RLS:
DB_APP_ROLE=quantia_app

# --- Redis (queue broker + cache) ---
REDIS_URL=redis://localhost:6379/0

# --- Object storage (S3-compatible; MinIO locally) ---
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET=quantia-data
S3_ACCESS_KEY_ID=change-me
S3_SECRET_ACCESS_KEY=change-me
S3_REGION=us-east-1

# --- Auth provider (Supabase Auth / Clerk / Auth0) ---
AUTH_PROVIDER=supabase
AUTH_JWT_AUDIENCE=quantia
AUTH_JWKS_URL=https://YOUR_AUTH_DOMAIN/.well-known/jwks.json

# --- LLM (Hybrid AI — METADATA ONLY crosses this boundary) ---
LLM_PROVIDER=anthropic
LLM_API_KEY=change-me
LLM_MODEL=claude-opus-4-8
LLM_ZERO_RETENTION=true            # must be true in prod
LLM_SELF_HOSTED_BASE_URL=          # set for vLLM/self-hosted mode

# --- Encryption (envelope encryption for user-supplied DB creds, etc.) ---
KMS_PROVIDER=local                 # local | aws-kms | gcp-kms
DATA_ENCRYPTION_KEY=change-me      # local dev only; use KMS in prod

# --- Limits / quotas ---
MAX_UPLOAD_MB=100
MAX_ROWS=2000000
