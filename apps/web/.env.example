# ── Quantia web — environment template ──────────────────────────────────────
# Copy to .env.local for local dev (git-ignored). In Vercel, set these as Project
# Environment Variables. Leave everything unset to run the free, local templated
# narrator with no network calls.

# Flip to 1 to route insights through the server-side LLM endpoint (/api/insights).
# Public (sent to the browser) — it only toggles the code path, never holds a secret.
NEXT_PUBLIC_LLM_ENABLED=0

# ── Server-side only (NEVER prefixed NEXT_PUBLIC_; never reaches the browser) ──
# Provider: anthropic | groq | openai | gemini | openrouter | openai-compat
#
# Recommendation:
#   • Best free + reliable -> gemini  (generous free tier; far fewer rate limits than groq)
#   • Best quality (paid)  -> anthropic + claude-haiku-4-5 (sharpest analytical writing; set a cap)
#   • groq's free tier has tight per-minute AND per-day token limits — fine for light use, but it
#     will fall back to the local templated narrator once the daily cap is hit.
LLM_PROVIDER=gemini

# Your API key for the chosen provider.
#   Google Gemini (free):https://aistudio.google.com/apikey
#   Groq (free tier):    https://console.groq.com/keys
#   OpenAI (paid):       https://platform.openai.com/api-keys
#   Anthropic (paid):    https://console.anthropic.com  (set a spending cap)
#   OpenRouter (mixed):  https://openrouter.ai/keys
LLM_API_KEY=

# Model id. OPTIONAL — leave blank to use a sensible per-provider default:
#   gemini -> gemini-2.5-flash   (or gemini-flash-latest)
#   groq   -> llama-3.3-70b-versatile
#   openai -> gpt-4o-mini
#   anthropic -> claude-haiku-4-5
LLM_MODEL=

# Only needed when LLM_PROVIDER=openai-compat (a custom OpenAI-compatible endpoint).
# For groq/openai/gemini/openrouter the base URL is built in.
LLM_BASE_URL=
